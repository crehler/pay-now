{
    "name": "crehler/pay-now",
    "description": "PayNow Shopware Integration",
    "type": "shopware-platform-plugin",
    "license": "proprietary",
    "version": "6.2.0",
    "authors": [
        {
            "name": "Crehler Sp. z o. o.",
            "email": "support@crehler.com",
            "homepage": "https://crehler.com",
            "role": "Developer"
        },
        {
            "name": "mElements S.A.",
            "email": "contact@melements.pl",
            "homepage": "https://melements.pl",
            "role": "Owner"
        }
    ],
    "support": {
        "email": "contact@melements.pl"
    },
    "autoload": {
        "psr-4": {
            "Crehler\\PayNow\\": "src/"
        }
    },
    "extra": {
        "shopware-plugin-class": "Crehler\\PayNow\\CrehlerPayNow",
        "plugin-icon": "src/Resources/config/paynowpayment.png",
        "label": {
            "de-DE": "Zahlungsgateway PayNow by CREHLER",
            "en-GB": "Payment Gateway PayNow by CREHLER",
            "pl-PL": "Bramka płatności PayNow by CREHLER"
        },
        "description": {
            "de-DE": "PayNow ist der Payment Service Provider der mBank. Schnelle und sichere Online-Zahlungen für Ihren Shop.",
            "en-GB": "PayNow is mBank's payment service provider. Fast and secure online payments for your store.",
            "pl-PL": "PayNow to operator płatności mBanku. Szybkie i bezpieczne płatności online dla Twojego sklepu."
        },
        "manufacturerLink": {
            "de-DE": "https://crehler.com/",
            "en-GB": "https://crehler.com/",
            "pl-PL": "https://crehler.com/"
        },
        "supportLink": {
            "de-DE": "https://crehler.com/",
            "en-GB": "https://crehler.com/",
            "pl-PL": "https://crehler.com/"
        }
    },
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "crehler/payment-bundle": "^6.0 >=6.0.2",
        "pay-now/paynow-php-sdk": "^2.4",
        "shopware/core": "~6.6 || ~6.7"
    },
    "require-dev": {
        "rector/rector": "^2.4"
    }
}
